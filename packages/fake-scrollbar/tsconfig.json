{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "declaration": true, // Generates the .d.ts files
    "declarationMap": true, // Links types back to your source code
    "sourceMap": true, // Helps with debugging
    "composite": true, // CRITICAL for monorepo references
    "rootDir": "src",
    "outDir": "dist",
    "experimentalDecorators": true, // Required for Lit @decorators
    "useDefineForClassFields": false, // Required for Lit compatibility
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@missing-js/*": ["../../*"] // Allows packages to find each other
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
